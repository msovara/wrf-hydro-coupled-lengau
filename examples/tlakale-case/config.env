# Tlakale case — Inkomati River catchment, coupled WRF-Hydro Phase 1 (1980–2010)
# Source this file before running setup or PBS jobs:
#   source config.env

# --- CHPC / project (edit before submit) ---
export PBS_PROJECT="${PBS_PROJECT:-YOUR_PROJECT}"
export PBS_QUEUE="${PBS_QUEUE:-normal}"

# --- Paths on Lengau ---
export WRF_MODULE="${WRF_MODULE:-chpc/earth/wrf-lengau-gcc-hydro}"
export WRF_ROOT="${WRF_ROOT:-/home/apps/chpc/earth/WRF-4.7.1-hydro-gcc}"
export WPS_DIR="${WPS_DIR:-${HOME}/WPS}"
export GEOG_DATA_PATH="${GEOG_DATA_PATH:-/home/apps/chpc/earth/CROCCO_Workshop/geog/WPS_GEOG}"

# --- Case layout ---
export CASE_ROOT="${CASE_ROOT:-${HOME}/cases/tlakale_case}"
export CASE_DIR="${CASE_DIR:-${CASE_ROOT}/wrf}"
export WPS_CASE_DIR="${WPS_CASE_DIR:-${CASE_ROOT}/wps}"
export ERA5_GRIB_DIR="${ERA5_GRIB_DIR:-${CASE_ROOT}/era5_grib}"

# --- Domain reference (Inkomati basin, ~25.5°S 31.5°E) ---
export REF_LAT="-25.5"
export REF_LON="31.5"

# --- Parallelism ---
export NP_REAL="${NP_REAL:-48}"
export NP_WRF="${NP_WRF:-48}"

# --- Simulation mode: test | year ---
# test  = January 2010 (workflow check)
# year  = calendar year (set RUN_YEAR)
export SIM_MODE="${SIM_MODE:-test}"
export RUN_YEAR="${RUN_YEAR:-1980}"

# --- Land surface: noah (2) or noahmp (5) ---
export LSM_OPTION="${LSM_OPTION:-noahmp}"
