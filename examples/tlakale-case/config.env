# Tlakale case — Inkomati River catchment, coupled WRF-Hydro Phase 1 (1980–2010)
# Source before any script:  source config.env

# --- CHPC / project ---
export PBS_PROJECT="${PBS_PROJECT:-ERTH0859}"

# Lengau queue limits (see README):
#   serial  — 1–23 cores, 48 h max  (WPS)
#   normal  — 25–240 cores/job, 48 h max  (real, wrf)
#   test    — 1–24 cores, 3 h max, 1 job  (quick smoke test only)
export PBS_QUEUE_WPS="${PBS_QUEUE_WPS:-serial}"
export PBS_QUEUE_PARALLEL="${PBS_QUEUE_PARALLEL:-normal}"
export PBS_QUEUE_TEST="${PBS_QUEUE_TEST:-test}"

export WALLTIME_WPS="${WALLTIME_WPS:-08:00:00}"
export WALLTIME_REAL="${WALLTIME_REAL:-08:00:00}"
export WALLTIME_WRF_TEST="${WALLTIME_WRF_TEST:-12:00:00}"
export WALLTIME_WRF_YEAR="${WALLTIME_WRF_YEAR:-48:00:00}"

# --- Paths on Lengau (tmogebisa lustre layout) ---
export WRF_MODULE="${WRF_MODULE:-chpc/earth/wrf-lengau-gcc-hydro}"
export WRF_ROOT="${WRF_ROOT:-/home/apps/chpc/earth/WRF-4.7.1-hydro-gcc}"
export WPS_DIR="${WPS_DIR:-/home/apps/chpc/earth/WRF-4.7.1-gcc/bin}"
export WPS_ROOT="${WPS_ROOT:-/home/apps/chpc/earth/WRF-4.7.1-gcc/build/WPS}"
export GEOG_DATA_PATH="${GEOG_DATA_PATH:-/home/apps/chpc/earth/CROCCO_Workshop/geog/WPS_GEOG}"

export EXAMPLE_DIR="${EXAMPLE_DIR:-/home/tmogebisa/lustre/WRF-Hydro_Coupled/examples/tlakale-case}"
export CASE_ROOT="${CASE_ROOT:-/home/tmogebisa/lustre/WRF-Hydro_Coupled/cases/my_hydro_run}"
export CASE_DIR="${CASE_DIR:-${CASE_ROOT}}"
export WPS_CASE_DIR="${WPS_CASE_DIR:-/home/tmogebisa/lustre/WRF-Hydro_Coupled/cases/wps}"
export ERA5_GRIB_DIR="${ERA5_GRIB_DIR:-/home/tmogebisa/lustre/WRF-Hydro_Coupled/era5_grib}"
export RESTART_ARCHIVE="${RESTART_ARCHIVE:-/home/tmogebisa/lustre/WRF-Hydro_Coupled/restarts}"

# --- Phase 1 analysis period ---
export PHASE1_START_YEAR="${PHASE1_START_YEAR:-1980}"
export PHASE1_END_YEAR="${PHASE1_END_YEAR:-2010}"
export TEST_YEAR="${TEST_YEAR:-2010}"
export TEST_MONTH_START="${TEST_MONTH_START:-01}"
export TEST_MONTH_END="${TEST_MONTH_END:-01}"

# --- Domain (Inkomati basin, ~25.5°S 31.5°E) ---
export REF_LAT="-25.5"
export REF_LON="31.5"

# --- Parallelism (must match PBS select and queue minimums) ---
export NP_WPS="${NP_WPS:-16}"
export NP_REAL="${NP_REAL:-48}"
export NP_WRF="${NP_WRF:-48}"
export NP_WRF_TEST="${NP_WRF_TEST:-24}"

# --- Simulation mode: test | year ---
export SIM_MODE="${SIM_MODE:-test}"
export RUN_YEAR="${RUN_YEAR:-1980}"
export RESTART="${RESTART:-false}"

# --- Production output intervals (year mode; test stays hourly) ---
export HISTORY_INTERVAL_YEAR="${HISTORY_INTERVAL_YEAR:-180}"       # WRF history (min)
export FRAMES_PER_OUTFILE_YEAR="${FRAMES_PER_OUTFILE_YEAR:-248}"   # ~1 month at 3-hourly
export HYDRO_OUT_DT_YEAR="${HYDRO_OUT_DT_YEAR:-180}"               # hydro out_dt (min)
export HYDRO_OUT_DT_TEST="${HYDRO_OUT_DT_TEST:-60}"                # hydro out_dt (min)

# --- Land surface: noah (2) or noahmp (5) ---
export LSM_OPTION="${LSM_OPTION:-noahmp}"

# --- WRF-Hydro GIS preprocessing ---
export GIS_REGFACT="${GIS_REGFACT:-4}"
export GIS_THRESHOLD="${GIS_THRESHOLD:-500}"
export GIS_ROUTING="${GIS_ROUTING:-True}"
export DEM_PATH="${DEM_PATH:-/home/tmogebisa/lustre/WRF-Hydro_Coupled/dem/inkomati_dem.tif}"
export GIS_TOOL_DIR="${GIS_TOOL_DIR:-${EXAMPLE_DIR}/gis/wrf_hydro_gis_preprocessor/wrfhydro_gis}"
